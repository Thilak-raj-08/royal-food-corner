APP_NAME="Royal Food Corner"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Colombo
APP_URL=https://YOUR-SUBDOMAIN.rf.gd

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=single
LOG_STACK=single
LOG_LEVEL=error

# ── InfinityFree MySQL (replace with values from cPanel → MySQL Databases) ──
DB_CONNECTION=mysql
DB_HOST=sql123.infinityfree.com
DB_PORT=3306
DB_DATABASE=if0_xxxxxxxx_rfc_db
DB_USERNAME=if0_xxxxxxxx
DB_PASSWORD=YOUR_DB_PASSWORD

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=rfc

FORCE_HTTPS=true

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@royalfoodcorner.rf.gd"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
