{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "echo 'No build needed - serving pre-built static export'",
  "outputDirectory": "static",
  "installCommand": "echo 'No dependencies needed'",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/menu",         "destination": "/menu.html" },
    { "source": "/gallery",      "destination": "/gallery.html" },
    { "source": "/reservations", "destination": "/reservations.html" },
    { "source": "/cart",         "destination": "/cart.html" },
    { "source": "/login",        "destination": "/login.html" },
    { "source": "/register",     "destination": "/register.html" },
    { "source": "/admin/login",  "destination": "/admin/login.html" }
  ],
  "headers": [
    {
      "source": "/build/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    }
  ]
}
